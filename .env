# ============================================================
# JURIDICO CRAWLER - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- Banco de Dados ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/juridico_crawler
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
API_SECRET_KEY=troque-por-uma-chave-segura-em-producao

# --- DataJud CNJ ---
# Chave pública do CNJ (funciona sem cadastro)
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br

# --- Anthropic Claude (para o AI Parser) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Firecrawl (scraping com JS, free tier: 500 req/mês) ---
FIRECRAWL_API_KEY=fc-2e1eeaadd4f1406aafac240385d1f412
TWOCAPTCHA_API_KEY=12c50b585c9a3fc779ba0d7b1bb06a2a

# --- Rate Limiting ---
CRAWLER_REQUESTS_PER_MINUTE=120
CRAWLER_MAX_RETRIES=3
CRAWLER_RETRY_DELAY=5

# --- Scheduler ---
# Horário de atualização diária (formato cron)
SCHEDULER_CRON_HORA=2
SCHEDULER_CRON_MINUTO=0

# --- Proxies Residenciais (ProxyScrape) ---
# Endpoint rotativo — troca de IP a cada conexão nova
# Formato: http://{api_key}-country-br:@residential.proxyscrape.com:6060
# Proxy desativado — DataJud CNJ cobre todos os tribunais sem necessidade de proxy.
# Os domínios esaj.*.jus.br são DNS interno da Rede JUS (inacessíveis publicamente).
# Para reativar proxy (ex: em VPS fora do Brasil), descomente:
# PROXY_LIST=http://user:pass@host:porta
PROXY_LIST=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
