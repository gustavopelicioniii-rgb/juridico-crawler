# ============================================================
# JURIDICO CRAWLER - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- Banco de Dados ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/juridico_crawler
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
# Gere uma chave forte em produção: `openssl rand -hex 32`
# Em API_ENVIRONMENT=production, o placeholder abaixo é recusado pela inicialização.
API_SECRET_KEY=troque-por-uma-chave-segura-em-producao
API_ENVIRONMENT=development

# --- CORS ---
# Lista separada por vírgula de origens permitidas para o frontend.
FRONTEND_ORIGINS=http://localhost:3333,http://localhost:5173

# --- DataJud CNJ ---
# Chave pública do CNJ (funciona sem cadastro)
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SnJSSmdzMHFhUXFCaVhpSHJlUjNmQQ==
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br

# --- Anthropic Claude (para o AI Parser) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Firecrawl (scraping com JS, free tier: 500 req/mês) ---
# Obtenha em https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# --- Proxies Residenciais Brasileiros ---
# Necessário para TJs que bloqueiam IPs internacionais (TJMG, TJRJ, TJPR, TJSC, TJRS, etc.)
# Formato: URL(s) separadas por vírgula. Suporta http://, https://, socks5://
# com autenticação: http://usuario:senha@host:porta
#
# ProxyScrape (residencial, país BR):
#   PROXY_LIST=http://{api_key}-country-br:@residential.proxyscrape.com:6060
#   Obs: se -country-br der erro, tente sem sufixo:
#   PROXY_LIST=http://{api_key}:@residential.proxyscrape.com:6060
#
# Outros provedores compatíveis com .jus.br:
#   Oxylabs:    PROXY_LIST=http://user_country-BR:pass@residential.oxylabs.io:10000
#   Smartproxy: PROXY_LIST=http://user:pass@gate.smartproxy.com:7000
#   IPRoyal:    PROXY_LIST=http://user:pass@geo.iproyal.com:12321
#
# Opção com múltiplos IPs fixos (round-robin):
#   PROXY_LIST=http://u:p@br1.proxy.com:8080,http://u:p@br2.proxy.com:8080
PROXY_LIST=

# --- Rate Limiting ---
CRAWLER_REQUESTS_PER_MINUTE=30
CRAWLER_MAX_RETRIES=3
CRAWLER_RETRY_DELAY=5

# --- Scheduler ---
# Horário de atualização diária (formato cron)
SCHEDULER_CRON_HORA=2
SCHEDULER_CRON_MINUTO=0

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- TJSP Documentos (Playwright) ---
# Credenciais para acesso ao portal eSaj e download de documentos
TJSP_LOGIN=
TJSP_SENHA=
DOWNLOAD_DOCUMENTOS=false
PASTA_DOCUMENTOS=./documentos
