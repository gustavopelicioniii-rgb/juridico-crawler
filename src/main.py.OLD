"""
Entry point da aplicação FastAPI — Juridico Crawler.
"""

import logging
from contextlib import asynccontextmanager
from typing import AsyncIterator

import structlog
from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import HTMLResponse, JSONResponse
from fastapi.staticfiles import StaticFiles

from src.api.routes import monitoramento, notificacoes, partes, prazos, processos
from src.api.routes import oab
from src.config import settings
from src.database.connection import create_tables, engine
from src.scheduler.jobs import criar_scheduler

# ============================================================
# Logging estruturado
# ============================================================
structlog.configure(
    processors=[
        structlog.processors.TimeStamper(fmt="iso"),
        structlog.stdlib.add_log_level,
        structlog.dev.ConsoleRenderer() if settings.api_debug else structlog.processors.JSONRenderer(),
    ],
    wrapper_class=structlog.make_filtering_bound_logger(
        getattr(logging, settings.log_level.upper(), logging.INFO)
    ),
    context_class=dict,
    logger_factory=structlog.PrintLoggerFactory(),
)

logging.basicConfig(level=settings.log_level.upper())
logger = structlog.get_logger(__name__)


# ============================================================
# Lifespan (startup / shutdown)
# ============================================================
@asynccontextmanager
async def lifespan(app: FastAPI) -> AsyncIterator[None]:
    """Inicializa recursos na subida e libera no desligamento."""
    logger.info("Iniciando Juridico Crawler API...")

    # Criar tabelas (em dev; em prod use as migrations SQL)
    if settings.api_debug:
        await create_tables()
        logger.info("Tabelas criadas/verificadas (modo dev)")

    # Iniciar scheduler
    scheduler = criar_scheduler()
    scheduler.start()
    logger.info(
        "Scheduler iniciado — próxima atualização às %02d:%02d",
        settings.scheduler_cron_hora,
        settings.scheduler_cron_minuto,
    )

    yield

    # Shutdown
    logger.info("Encerrando API...")
    scheduler.shutdown(wait=False)
    await engine.dispose()
    logger.info("API encerrada")


# ============================================================
# Aplicação FastAPI
# ============================================================
app = FastAPI(
    title="Juridico Crawler API",
    description=(
        "Sistema de crawling jurídico. Consulta processos no DataJud (CNJ) "
        "e tribunais brasileiros, extrai partes, movimentações e expõe via REST."
    ),
    version="1.0.0",
    docs_url="/docs",
    redoc_url="/redoc",
    lifespan=lifespan,
)

# CORS — agora permitindo todos para evitar bloqueios de conectividade local
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# ============================================================
# Routers
# ============================================================
app.include_router(processos.router)
app.include_router(partes.router)
app.include_router(monitoramento.router)
app.include_router(notificacoes.router)
app.include_router(prazos.router)
app.include_router(oab.router)


# ============================================================
# Endpoints utilitários
# ============================================================
@app.get("/health", tags=["Sistema"])
async def health_check() -> JSONResponse:
    """Verificação de saúde da API."""
    from src.scheduler.jobs import obter_scheduler
    sched = obter_scheduler()
    return JSONResponse({
        "status": "ok",
        "versao": "1.0.0",
        "scheduler": "rodando" if sched and sched.running else "parado",
    })


@app.get("/", include_in_schema=False)
async def dashboard() -> HTMLResponse:
    """Serve o dashboard visual."""
    import pathlib
    html = pathlib.Path("src/static/dashboard.html").read_text(encoding="utf-8")
    return HTMLResponse(content=html)


@app.get("/stats", tags=["Sistema"])
async def stats() -> JSONResponse:
    """Retorna contagens agregadas para o dashboard."""
    from sqlalchemy import func, select, text
    from src.database.connection import AsyncSessionLocal
    from src.database.models import Movimentacao, Parte, Processo

    async with AsyncSessionLocal() as db:
        total_proc = (await db.execute(select(func.count(Processo.id)))).scalar_one()
        total_part = (await db.execute(select(func.count(Parte.id)))).scalar_one()
        total_movs = (await db.execute(select(func.count(Movimentacao.id)))).scalar_one()

    return JSONResponse({
        "total_processos": total_proc,
        "total_partes": total_part,
        "total_movimentacoes": total_movs,
    })


@app.get("/debug/tjsp/{numero_cnj}", tags=["Debug"])
async def debug_tjsp(numero_cnj: str) -> JSONResponse:
    """
    Busca um processo no TJSP eSaj e retorna dados parseados + diagnóstico de seletores.
    Inclui prévia do HTML recebido para depuração de estrutura.
    Disponível apenas em modo debug (API_DEBUG=true).
    """
    if not settings.api_debug:
        from fastapi import HTTPException
        raise HTTPException(status_code=404, detail="Not found")

    from src.crawlers.tjsp import TJSPCrawler, ESAJ_BASE
    import re as _re

    resultado: dict = {
        "numero_cnj": numero_cnj,
        "html_preview": None,
        "diagnostico": {},
        "partes": [],
        "movimentacoes": [],
    }

    async with TJSPCrawler(requests_per_minute=60) as c:
        partes_num = c._extrair_partes_numero(numero_cnj)
        if not partes_num:
            return JSONResponse({"erro": "Número CNJ inválido"}, status_code=400)

        params = {"processo.foro": partes_num["origem"], "processo.numero": numero_cnj}
        try:
            resp = await c._get(f"{ESAJ_BASE}/cpopg/show.do", params=params)
            html = resp.text
        except Exception as e:
            return JSONResponse({"erro": str(e)}, status_code=502)

        # Diagnóstico de seletores
        try:
            from selectolax.parser import HTMLParser
            tree = HTMLParser(html)
            resultado["diagnostico"] = {
                "tablePartesPrincipais": tree.css_first("#tablePartesPrincipais") is not None,
                "tableTodasPartes": tree.css_first("#tableTodasPartes") is not None,
                "spans_nomeParteEAdvogado": len(tree.css("span.nomeParteEAdvogado")),
                "td_label": len(tree.css("td.label")),
                "tr_fundoClaro": len(tree.css("tr.fundoClaro")),
                "tr_fundoEscuro": len(tree.css("tr.fundoEscuro")),
                "tabelaMovimentacoes": tree.css_first("#tabelaTodasMovimentacoes") is not None,
                "classeProcesso": tree.css_first("#classeProcesso") is not None,
            }
        except Exception as e:
            resultado["diagnostico"]["erro_selectolax"] = str(e)

        # Retorna trecho do HTML em volta das partes (busca por "nomeParteEAdvogado" ou "Partes")
        idx = html.find("nomeParteEAdvogado")
        if idx < 0:
            idx = html.lower().find("partes do processo")
        if idx >= 0:
            resultado["html_preview"] = html[max(0, idx - 200): idx + 3000]
        else:
            resultado["html_preview"] = html[:3000]

        # Processar normalmente
        proc = c._parse_detalhe(html, numero_cnj)

    resultado["classe"] = proc.classe_processual
    resultado["vara"] = proc.vara
    resultado["comarca"] = proc.comarca
    resultado["situacao"] = proc.situacao
    resultado["total_partes"] = len(proc.partes)
    resultado["total_movimentacoes"] = len(proc.movimentacoes)
    resultado["partes"] = [
        {"nome": p.nome, "tipo": p.tipo_parte, "polo": p.polo, "oab": p.oab}
        for p in proc.partes
    ]
    resultado["movimentacoes"] = [
        {"data": str(m.data_movimentacao), "descricao": m.descricao[:120]}
        for m in proc.movimentacoes[:5]
    ]
    return JSONResponse(resultado)


@app.get("/tribunais", tags=["Sistema"])
async def listar_tribunais() -> JSONResponse:
    """Lista todos os tribunais suportados pelo DataJud."""
    from src.crawlers.datajud import TRIBUNAL_ENDPOINT
    return JSONResponse({
        "total": len(TRIBUNAL_ENDPOINT),
        "tribunais": sorted(TRIBUNAL_ENDPOINT.keys()),
    })
